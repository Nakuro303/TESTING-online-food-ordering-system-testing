    {
      "name": "Cancel Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code adalah 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response mengandung pesan pembatalan order\", function () {",
              "    var responseText = pm.response.text();",
              "    pm.expect(responseText).to.satisfy(function(text) {",
              "        return text.includes(\"cancelled\") || text.includes(\"Invalid\") || text.includes(\"Order has been\");",
              "    });",
              "});",
              "",
              "pm.test(\"Response body tidak kosong\", function () {",
              "    pm.expect(pm.response.text()).to.not.be.empty;",
              "});"
            ],
